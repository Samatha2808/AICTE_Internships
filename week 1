# Week 1 - Smart Irrigation Internship

# Step 1: Libraries import cheyyadam
import pandas as pd
import matplotlib.pyplot as plt

# Step 2: Sample Data create cheddam
data = {
    'Moisture_Level': [70, 50, 30, 60, 20],
    'Temperature': [30, 32, 34, 28, 36]
}
df = pd.DataFrame(data)

# Step 3: Moisture Level check cheddam
def irrigation_status(moisture):
    if moisture < 40:
        return "Needs Irrigation"
    else:
        return "No Irrigation Needed"

df['Irrigation_Status'] = df['Moisture_Level'].apply(irrigation_status)
print(df)

# Step 4: Plot cheyyadam
plt.plot(df['Moisture_Level'], label='Moisture Level', marker='o')
plt.plot(df['Temperature'], label='Temperature', marker='x')
plt.title("Smart Irrigation Analysis")
plt.xlabel("Sample Number")
plt.ylabel("Values")
plt.legend()
plt.grid(True)
plt.show()
